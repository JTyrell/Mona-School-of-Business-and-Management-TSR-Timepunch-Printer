{
  "name": "timesheet-printer-monolith",
  "version": "1.0.0",
  "description": "Monolith Deployment for Timepunch Printer",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "postinstall": "npm run install:frontend && npm run install:backend",
    "install:frontend": "npm install --prefix frontend",
    "install:backend": "python -m pip install -r requirements.txt",
    "install:playwright": "python -m playwright install chromium",
    "build": "npm run build:frontend",
    "build:frontend": "npm run build --prefix frontend",
    "start": "python -m uvicorn backend.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "python -m uvicorn backend.main:app --reload"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0"
  }
}
